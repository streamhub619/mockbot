# ── Server ───────────────────────────────────────────────────
PORT=
NODE_ENV=

# ── PostgreSQL ───────────────────────────────────────────────
# Option A — full URL (preferred for deployment)
DATABASE_URL=

# Option B — individual vars (used as fallback if DATABASE_URL is absent)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=
MAX_FILE_SIZE_MB=

# ── Optional: AI Evaluation  ──────────────────────
GEMINI_API_KEY=
